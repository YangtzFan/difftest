{
  "$schema": "https://raw.githubusercontent.com/EmmyLuaLs/emmylua-analyzer-rust/refs/heads/main/crates/emmylua_code_analysis/resources/schema.json",
  "runtime": {
    "requireLikeFunction": [
      "load",
      "dofile"
    ],
    "version": "LuaJIT"
  },
  "diagnostics": {
    "disable": [
      "unnecessary-assert",
      "unnecessary-if",
      "invert-if"
    ],
    "severity": {
      "type-not-found": "error",
      "duplicate-type": "error"
    }
  },
  "hint.enable": true,
  "workspace": {
    "enableReindex": true,
    "reindexDuration": 5000,
    "encoding": "utf-8",
    "ignoreDir": [
      ".vscode",
      ".xmake",
      "build",
      "temp"
    ],
    "ignoreGlobs": [],
    "library": [
      "$VERILUA_HOME/src/lua"
    ]
  }
}
